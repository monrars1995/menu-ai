{
  "name": "menuai-menu",
  "version": "3.6.11",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack -p 8002",
    "build": "next build --webpack",
    "prepare:standalone": "mkdir -p .next/standalone/.next .next/standalone/public && cp -R .next/static .next/standalone/.next/ && cp -R public/. .next/standalone/public/",
    "start": "npm run prepare:standalone && HOSTNAME=0.0.0.0 PORT=${PORT:-8002} node .next/standalone/server.js",
    "lint": "next lint",
    "test:ui": "vitest run",
    "test:ui:watch": "vitest"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "^16.2.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.3.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.19",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5",
    "vitest": "^2.1.8"
  }
}
