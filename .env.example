# ============================================================
# Menu.AI — Variáveis de Ambiente (.env.example)
# Copie para .env e preencha com seus valores reais.
# NUNCA commite o arquivo .env (já está no .gitignore).
# ============================================================

# ============================================================
# MODO E SEGURANÇA
# ============================================================
# DEBUG=true  → Logs detalhados, CORS permissivo, recarrega em dev
# DEBUG=false → Produção: CORS restrito, sem reload, validações rigorosas
DEBUG=true

# CORS_ORIGINS: lista separada por vírgulas dos domínios do frontend.
# EM PRODUÇÃO (DEBUG=false): se vazio, o app usa apenas localhost.
# Exemplo: CORS_ORIGINS=https://app.menuai.com.br,https://admin.menuai.com.br
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ============================================================
# BANCO DE DADOS (PostgreSQL obrigatório em produção)
# ============================================================
# Use a MESMA URL em toda a stack (app, Alembic, seed_data).
# Prioridade de leitura: SUPABASE_DB_URL > DATABASE_URL > SQLite (fallback dev)
#
# Opção A — Docker local (dev):
DATABASE_URL=postgresql+psycopg2://menuai:menuai123@127.0.0.1:5432/menuai_db
#
# Opção B — Supabase (produção ou dev):
# SUPABASE_DB_URL=postgresql://postgres.[PROJETO]:[SENHA]@aws-0-[REGION].pooler.supabase.com:5432/postgres?sslmode=require
# SUPABASE_URL=https://[PROJETO].supabase.co
# SUPABASE_PUBLISHABLE_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Logs SQL (true para debug, false em produção)
DB_ECHO=false

# ============================================================
# AUTENTICAÇÃO JWT
# ============================================================
# Gere uma chave segura com:
#   python -c "import secrets; print(secrets.token_hex(32))"
# EM PRODUÇÃO: deve ser diferente do valor padrão abaixo.
SECRET_KEY=menuai-secret-key-TROQUE-EM-PRODUCAO

# Duração do token em horas (padrão: 24).
# ATENÇÃO: 0 = token NUNCA expira (inseguro, só para testes).
TOKEN_EXPIRE_HOURS=24

# ============================================================
# LLM — OpenAI, Gemini e OpenRouter via LiteLLM
# ============================================================
# Configure pelo menos um provedor. O padrão recomendado é OpenAI GPT-5.5.
OPENAI_API_KEY=
GEMINI_API_KEY=
# GOOGLE_API_KEY também é aceito como fallback para Gemini.
# OPENROUTER_API_KEY=

# Modelo padrão quando o request não envia llm_model.
# IDs disponíveis: openai-gpt-5.5, gemini-3.1-pro-preview, gemini-3-flash-preview,
# gemini-3.1-flash-lite, queen-3.6, glm-5-1, kimi-k2.5
MENUAI_DEFAULT_LLM_MODEL=openai-gpt-5.5
# Modo padrão de geração: fast (1 chamada estruturada + validações) ou full (pipeline completo legado).
MENUAI_GENERATION_MODE=fast
# Legado ainda aceito:
# OPENROUTER_DEFAULT_MODEL=queen-3.6

# Temperatura das chamadas LLM (0.0 a 2.0, padrão 0.7)
LLM_TEMPERATURE=0.7
# Timeout base por chamada no roteador LLM (segundos)
MENUAI_LLM_REQUEST_TIMEOUT_SECONDS=55
# Guarda extra para timeout duro local (segundos)
MENUAI_LLM_HARD_TIMEOUT_EXTRA_SECONDS=8

# Opcional: atribuição no ranking da OpenRouter
# OPENROUTER_HTTP_REFERER=https://seu-dominio.tld
# OPENROUTER_APP_TITLE=Menu.AI

# Overrides se o catálogo OpenRouter mudar:
# OPENROUTER_SLUG_QUEEN_36=qwen/qwen3.6-plus
# OPENROUTER_SLUG_GLM_51=z-ai/glm-5.1
# OPENROUTER_SLUG_KIMI_K25=moonshotai/kimi-k2.5

# ============================================================
# EMBEDDINGS — Base vetorial (pgvector)
# ============================================================
# Por padrão usa OpenRouter como endpoint compatível OpenAI.
EMBEDDING_API_KEY=sk-or-v1-sua_chave_aqui
EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_DIMENSION=1536
EMBEDDING_BASE_URL=https://openrouter.ai/api/v1

# ============================================================
# SERVIDOR PRINCIPAL
# ============================================================
PORT=8000

# ============================================================
# ADMIN — segunda aplicação (processo distinto)
# ============================================================
ADMIN_PORT=8001
ADMIN_HOST=0.0.0.0
# Em produção: false
ADMIN_RELOAD=false

# CORS do painel admin (lista separada por vírgulas)
ADMIN_CORS_ORIGINS=http://localhost:8001

# Acesso admin via API Key (alternativa ao JWT).
# Se definida, requests com header X-Admin-Api-Key podem acessar.
# MENUAI_ADMIN_API_KEY=chave-secreta-admin

# UUID do usuário a impersonar quando usa API Key (opcional).
# Se vazio, usa o primeiro super_admin encontrado.
# MENUAI_ADMIN_IMPERSONATE_USER_ID=00000000-0000-0000-0000-000000000000

# Em DEBUG=true, gera JWT de teste para este email (só dev)
# MENUAI_ADMIN_DEV_EMAIL=admin@exemplo.com

# ============================================================
# FLAGS DE FUNCIONALIDADE
# ============================================================
# Geração de cardápios sem autenticação JWT (APENAS DEV/DEMO)
DEMO_GERAR_SEM_AUTH=true

# Permite registro aberto de novos usuários (APENAS DEV)
ALLOW_OPEN_REGISTRO=true

# Cria tabelas automaticamente no startup (dev: true, produção: false → use Alembic)
CREATE_ALL_ON_START=false

# Empresa usada em DEMO_GERAR_SEM_AUTH quando o body não envia empresa_id
DEFAULT_EMPRESA_ID=00000000-0000-0000-0000-000000000001

# ============================================================
# PERFORMANCE / CACHE
# ============================================================
# TTL em segundos para cache em memória de estatísticas de fichas.
# Aumente se o volume de dados for grande.
FICHAS_DB_STATS_TTL=60
# Budget total para geração rápida (segundos)
MENUAI_FAST_BUDGET_SECONDS=300
# Timeout por tentativa LLM no modo rápido (segundos)
MENUAI_FAST_LLM_ATTEMPT_TIMEOUT_SECONDS=55
# Máximo de tentativas (modelo + fallbacks) no modo rápido
MENUAI_FAST_LLM_MAX_ATTEMPTS=3
# Quantidade de fichas por bucket enviada ao prompt (reduz tokens/latência)
MENUAI_FAST_PROMPT_CATALOG_LIMIT=24
# Limite máximo de caracteres do catálogo serializado no prompt
MENUAI_FAST_PROMPT_CATALOG_MAX_CHARS=14000
# Limite máximo de caracteres para resumo de regras do contrato no prompt
MENUAI_FAST_PROMPT_RULES_MAX_CHARS=2400

# ============================================================
# DEV / SCRIPTS (não usados em produção)
# ============================================================
# Credenciais do admin de desenvolvimento (scripts/ensure_dev_admin.py)
# MENUAI_DEV_ADMIN_EMAIL=admin-dev@menuai.local
# MENUAI_DEV_ADMIN_PASSWORD=MenuAI_dev_2026

# Caminho do XLSX para importação inicial de fichas técnicas (seed_data.py)
# MENUAI_FICHAS_IMPORT_XLSX=./template_fichas_tecnicas_menuai.xlsx

# URL para health check do scripts/verify_stack.py
# VERIFY_STACK_HEALTH_URL=http://127.0.0.1:8000/api/health

# ============================================================
# CHECKLIST DE PRODUÇÃO
# ============================================================
# Antes de fazer deploy, verifique:
#
# [ ] DEBUG=false
# [ ] SECRET_KEY gerada com secrets.token_hex(32) e diferente do padrão
# [ ] CORS_ORIGINS preenchido com domínios reais do frontend
# [ ] DEMO_GERAR_SEM_AUTH=false
# [ ] ALLOW_OPEN_REGISTRO=false
# [ ] CREATE_ALL_ON_START=false (use: alembic upgrade head)
# [ ] TOKEN_EXPIRE_HOURS > 0 (ex: 24)
# [ ] DATABASE_URL ou SUPABASE_DB_URL aponta para PostgreSQL (não SQLite)
# [ ] Pelo menos uma chave LLM válida e com créditos: OPENAI_API_KEY, GEMINI_API_KEY/GOOGLE_API_KEY ou OPENROUTER_API_KEY
# [ ] SUPABASE_URL, SUPABASE_PUBLISHABLE_KEY, SUPABASE_SERVICE_ROLE_KEY configurados
# [ ] DB_ECHO=false
# [ ] .env NÃO está versionado no git
# [ ] Teste: python3 scripts/verify_stack.py
#
