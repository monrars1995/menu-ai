# ============================================================
# Menu.AI v3.1.0 — Variáveis de Ambiente
# Desenvolvimento local suportado: PostgreSQL em Docker
# ============================================================

# ============================================================
# BANCO DE DADOS
# ============================================================
# Use a MESMA DATABASE_URL em toda a stack (app, Alembic, seed_data).
# No desenvolvimento local, a configuração suportada é PostgreSQL via Docker Compose.
DATABASE_URL=postgresql+psycopg2://menuai:menuai123@127.0.0.1:5432/menuai_db
# Produção / Supabase:
# Use a connection string Postgres do projeto Supabase.
# Para SQLAlchemy ORM e Alembic, prefira direct connection ou Supavisor session mode.
# SUPABASE_DB_URL=postgresql://postgres:[SENHA]@db.mnqpgpckgqevepgfobzn.supabase.co:5432/postgres
# SUPABASE_URL=https://mnqpgpckgqevepgfobzn.supabase.co
# SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# SUPABASE_SECRET_KEY=sb_secret_...
# Compatibilidade com projects antigos:
# SUPABASE_ANON_KEY=...
# SUPABASE_SERVICE_ROLE_KEY=...

# Ativar logs SQL (útil para debug, desativar em produção)
DB_ECHO=false

# Geração sem JWT (só dev): empresa usada se o body não enviar empresa_id
DEFAULT_EMPRESA_ID=00000000-0000-0000-0000-000000000001
DEBUG=true
DEMO_GERAR_SEM_AUTH=true
ALLOW_OPEN_REGISTRO=true
CREATE_ALL_ON_START=false

# Diagnóstico: `python3 scripts/verify_stack.py` (também documentado em INICIAR.md / CLAUDE.md)

# ============================================================
# AUTENTICAÇÃO JWT
# ============================================================
# Gere uma chave segura com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=menuai-secret-key-TROQUE-EM-PRODUCAO

# Duração do token em horas (padrão: 24h)
TOKEN_EXPIRE_HOURS=24

# ============================================================
# LLM — OpenRouter (fluxo único suportado)
# ============================================================
# Chave: https://openrouter.ai/settings/keys
# Endpoint base: https://openrouter.ai/api/v1
# Modelos expostos na API/UI: queen-3.6, glm-5-1, kimi-k2.5 (ver GET /api/llm-models)
OPENROUTER_API_KEY=sk-or-v1-sua_chave_aqui
OPENROUTER_DEFAULT_MODEL=queen-3.6
# Overrides opcionais se o catálogo OpenRouter mudar:
# OPENROUTER_SLUG_QUEEN_36=qwen/qwen3.6-plus
# OPENROUTER_SLUG_GLM_51=z-ai/glm-5.1
# OPENROUTER_SLUG_KIMI_K25=moonshotai/kimi-k2.5
# Opcional (atribuição na OpenRouter):
# OPENROUTER_HTTP_REFERER=https://seu-dominio.tld
# OPENROUTER_APP_TITLE=Menu.AI

# ============================================================
# EMBEDDINGS — Base vetorial (Supabase pgvector)
# ============================================================
# Modelo e credenciais para gerar embeddings. A base vetorial usa pgvector no Supabase.
# Por padrão, usa um endpoint compatível com OpenAI.
EMBEDDING_API_KEY=sua_chave_embeddings_aqui
EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_DIMENSION=1536
# OpenRouter também expõe endpoint compatível com OpenAI para embeddings.
EMBEDDING_BASE_URL=https://openrouter.ai/api/v1

# ============================================================
# SERVIDOR
# ============================================================
PORT=8000

# ============================================================
# ADMIN — segunda app (mesmo código, processo distinto)
# ============================================================
# ADMIN_PORT=8001
# python3 run_admin.py
# Com DEBUG=true, a página inicial do admin (/) mostra um JWT de teste se existir admin/super_admin na BD.
# MENUAI_ADMIN_DEV_EMAIL=admin@exemplo.com   # opcional: qual user usar para esse JWT em dev
# Utilizador dev (scripts/ensure_dev_admin.py com DEBUG=true):
# MENUAI_DEV_ADMIN_EMAIL=admin-dev@menuai.local
# MENUAI_DEV_ADMIN_PASSWORD=MenuAI_dev_2026
# Autenticação: JWT (role admin ou super_admin) ou, se definido:
# MENUAI_ADMIN_API_KEY=...
# MENUAI_ADMIN_IMPERSONATE_USER_ID=<uuid opcional; senão primeiro super_admin>
# ADMIN_CORS_ORIGINS=http://localhost:8001
